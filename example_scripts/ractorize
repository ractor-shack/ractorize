#!/usr/bin/env ruby

require "pry"
require "pry-byebug"

require_relative "../src/ractorize"
require 'timeout'

class Doubler
  def set(integer) = @i = integer

  def get
    sleep 3
    @i
  end

  def double = @i *= 2
end

doubler = Doubler.new
# puts "doubler.object_id"
# puts doubler.object_id

doubler.set(10)
doubler.double
puts doubler.get

doubler = Doubler.new
# puts "doubler.object_id"
# puts doubler.object_id
ractorized_doubler = Ractorize[doubler]

ractorized_doubler.set(100)
ractorized_doubler.double
ractorized_doubler.get

at_exit do
  if Ractorize.instances.any?
    begin
      Timeout.timeout(1) do
        Ractorize.instances.each(&:close)
        Ractorize.instances.each(&:join)
      end
    rescue Timeout::Error
      Ractorize.instances.reject(&:__closed__?).each do |ractorized_object|
        warn "Timeout while closing ractorized object: #{ractorized_object}"
      end
    end
  end
end
